# Copy this file to .env and fill in your Gemini API key.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Teams (or generic) webhook URL for async-review notifications.
# Used by: python3 bootstrap.py ... --async-review
REVIEW_NOTIFY_WEBHOOK_URL=
