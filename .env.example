# Copy this file to .env and fill in your Gemini API key.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Teams (or generic) webhook URL for async-review notifications.
# Used by: python3 bootstrap.py ... --async-review
REVIEW_NOTIFY_WEBHOOK_URL=

# Optional: Durable runtime storage backend for Streamlit Cloud.
# If not set, runtime files stay local/ephemeral.
RUNTIME_STORAGE_BACKEND=local

# Use a separate repository for runtime artifacts, for example:
# your-org/ci-sponsor-guide-runtime
RUNTIME_STORAGE_GITHUB_REPO=

# GitHub Personal Access Token with repository contents write access.
# Prefer setting this only in Streamlit Cloud secrets (not committed to git).
RUNTIME_STORAGE_GITHUB_TOKEN=

# Runtime artifact branch in the runtime repository.
RUNTIME_STORAGE_GITHUB_BRANCH=runtime-data

# Path prefix in the runtime repository where program folders are synced.
RUNTIME_STORAGE_GITHUB_PREFIX=runtime/programs
