# CI Sponsor Guide Tool — Streamlit secrets template
#
# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud, paste the same key/value pairs into
# App settings > Secrets instead of keeping this file.
#
# secrets.toml is listed in .gitignore and must never be committed.

# ── Microsoft Azure AD OAuth (required for authentication) ────────────────────
#
# Use this when your institution's email is hosted on Microsoft 365 / Azure AD
# (i.e. staff sign in with their institutional email via Outlook / Teams).
#
# Steps to obtain credentials:
#   1. Go to https://portal.azure.com and sign in with an admin account.
#   2. Navigate to Azure Active Directory > App registrations > New registration.
#   3. Set "Supported account types" to:
#        "Accounts in this organizational directory only" (single-tenant, recommended)
#        or "Accounts in any organizational directory" (multi-tenant)
#   4. Under "Redirect URI", choose "Web" and add:
#        Local dev : http://localhost:8501/oauth2callback
#        Production: https://<your-app>.streamlit.app/oauth2callback
#      You can add both at once — Azure allows multiple redirect URIs.
#   5. After registration, copy the "Application (client) ID" → client_id below.
#   6. Copy the "Directory (tenant) ID" → paste into server_metadata_url below.
#   7. Go to Certificates & secrets > New client secret, copy the value → client_secret.
#   8. Generate a long random string for cookie_secret, e.g.:
#        python3 -c "import secrets; print(secrets.token_hex(32))"

[auth]
redirect_uri        = "http://localhost:8501/oauth2callback"
cookie_secret       = "REPLACE_WITH_A_LONG_RANDOM_STRING"
client_id           = "REPLACE_WITH_AZURE_APPLICATION_CLIENT_ID"
client_secret       = "REPLACE_WITH_AZURE_CLIENT_SECRET"
server_metadata_url = "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/v2.0/.well-known/openid-configuration"

# ── Email allowlist (optional) ─────────────────────────────────────────────────
#
# List every institutional email address that should be allowed to access the tool.
# Remove this entire section (or leave emails empty) to allow any account in your
# Azure AD tenant that successfully authenticates.

[allowed_users]
emails = [
    "alice@yourinstitution.edu",
    "bob@yourinstitution.edu",
]

# ── Runtime persistence (optional) ────────────────────────────────────────────
#
# Uncomment and fill in to sync program files to a GitHub repository so they
# survive Streamlit Cloud process restarts.
#
# RUNTIME_STORAGE_BACKEND       = "github"
# RUNTIME_STORAGE_GITHUB_REPO   = "your-org/ci-sponsor-guide-runtime"
# RUNTIME_STORAGE_GITHUB_TOKEN  = "ghp_..."
# RUNTIME_STORAGE_GITHUB_BRANCH = "runtime-data"
#
# GEMINI_API_KEY is read from the environment; on Streamlit Cloud set it via
# App settings > Secrets as a plain key rather than inside a TOML section:
#
# GEMINI_API_KEY = "your-gemini-api-key"
